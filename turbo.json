{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "lint:check": {
      "dependsOn": ["^lint:check"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "code-review": {
      "dependsOn": ["lint:check", "typecheck", "test"]
    }
  }
}