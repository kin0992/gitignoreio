{
  "name": "gitignoreio-sdk",
  "version": "0.0.0",
  "description": "SDK for gitignore.io API",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "gitignore",
    "sdk",
    "api"
  ],
  "author": "Marco Comi",
  "license": "ISC",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "gitignoreio-eslint-config": "workspace:*",
    "@types/node": "^22.0.0",
    "eslint": "catalog:lint",
    "tsup": "^8.0.0",
    "typescript": "catalog:core",
    "vitest": "^3.2.4",
    "vitest-mock-extended": "^3.1.0"
  }
}
