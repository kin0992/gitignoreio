{
  "name": "gitignoreio-sdk",
  "version": "0.2.0",
  "description": "SDK for gitignore.io API",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "gitignore",
    "sdk",
    "api"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "catalog:core",
    "@vitest/coverage-v8": "catalog:core",
    "eslint": "catalog:lint",
    "gitignoreio-eslint-config": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "catalog:core",
    "vitest": "catalog:core",
    "vitest-mock-extended": "^3.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kin0992/gitignoreio.git",
    "directory": "packages/gitignoreio-sdk"
  },
  "author": "Marco Comi",
  "license": "ISC",
  "dependencies": {
    "neverthrow": "^8.2.0"
  }
}
