{
  "name": "gitignoreio-cli",
  "version": "0.0.0",
  "description": "CLI for gitignore.io API",
  "type": "module",
  "main": "bin/index.js",
  "bin": {
    "gitignoreio": "bin/index.js"
  },
  "files": [
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "gitignore",
    "cli",
    "api"
  ],
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "catalog:core",
    "@vitest/coverage-v8": "catalog:core",
    "eslint": "catalog:lint",
    "gitignoreio-eslint-config": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "catalog:core",
    "vitest": "catalog:core"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "gitignoreio-sdk": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kin0992/gitignoreio.git",
    "directory": "apps/gitignoreio-cli"
  },
  "author": "Marco Comi",
  "license": "ISC"
}
